# URL do backend (local)
VITE_API_URL=http://127.0.0.1:3001

# URL do backend (produção Vercel)
# VITE_API_URL=https://gestao-criatorio-api.vercel.app

# Nome do cookie CSRF definido pelo backend
VITE_CSRF_COOKIE_NAME=plumar_csrf

# Só habilite mocks durante desenvolvimento local controlado
VITE_ENABLE_MOCKS=false
