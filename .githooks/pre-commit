#!/usr/bin/env bash
# =============================================================================
# PLUMAR — pre-commit hook de seguranca
# Bloqueia commits que contenham arquivos .env (exceto *.example / *.secrets.example)
# e detecta padroes comuns de secret hardcoded.
#
# Ativar no clone:
#   git config core.hooksPath .githooks
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
YLW='\033[0;33m'
GRN='\033[0;32m'
NC='\033[0m'

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
  exit 0
fi

fail=0

# ---------------------------------------------------------------------------
# 1. Bloqueia arquivos .env (exceto *.example)
# ---------------------------------------------------------------------------
while IFS= read -r f; do
  base=$(basename "$f")
  case "$base" in
    *.example) continue ;;
  esac
  case "$f" in
    *.env | *.env.*)
      printf "${RED}[BLOCK] arquivo de env nao pode ser commitado: %s${NC}\n" "$f" >&2
      fail=1
      ;;
  esac
done <<< "$STAGED"

# ---------------------------------------------------------------------------
# 2. Detecta padroes de secret no diff staged
# ---------------------------------------------------------------------------
# Padroes focados em reducao de falso-positivo: procuram prefixos/estruturas
# comuns, nao apenas "secret=xxx".
PATTERNS=(
  # AWS
  'AKIA[0-9A-Z]{16}'
  'aws_secret_access_key[[:space:]]*=[[:space:]]*[A-Za-z0-9/+=]{40}'
  # Google API
  'AIza[0-9A-Za-z_-]{35}'
  # GitHub tokens
  'gh[pousr]_[A-Za-z0-9]{36,}'
  # Slack
  'xox[abprs]-[0-9A-Za-z-]{10,}'
  # Mercado Pago
  'APP_USR-[0-9]{16}-[0-9]{6}-[a-f0-9]{32}-[0-9]+'
  # Generic: chave privada inline
  '-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----'
  # JWT completo (3 segmentos base64 >= 100 chars)
  'eyJ[A-Za-z0-9_-]{20,}\.eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}'
  # Azure client secret (V4z8Q~... etc)
  '[A-Z][0-9][a-zA-Z][0-9][A-Z]~[A-Za-z0-9._~-]{30,}'
)

DIFF=$(git diff --cached -U0 -- . ':(exclude)*.md' ':(exclude)*.example' 2>/dev/null || true)

if [ -n "$DIFF" ]; then
  for pat in "${PATTERNS[@]}"; do
    if hits=$(printf '%s' "$DIFF" | grep -EnH --color=never "^+.*${pat}" 2>/dev/null | grep -v '^+++'); then
      if [ -n "$hits" ]; then
        printf "${RED}[BLOCK] padrao de secret detectado:${NC}\n" >&2
        printf "        %s\n" "$pat" >&2
        printf "%s\n" "$hits" | head -5 >&2
        fail=1
      fi
    fi
  done
fi

if [ "$fail" -ne 0 ]; then
  printf "\n${YLW}Commit abortado pelo hook de seguranca.${NC}\n" >&2
  printf "${YLW}Se for falso-positivo, reveja o diff. Em ultima instancia:${NC}\n" >&2
  printf "  git commit --no-verify   ${RED}(nao recomendado)${NC}\n" >&2
  exit 1
fi

printf "${GRN}[ok]${NC} pre-commit security check passou (%d arquivos).\n" "$(printf '%s\n' "$STAGED" | wc -l | tr -d ' ')"
exit 0
