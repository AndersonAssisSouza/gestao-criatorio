# ─── AZURE / SHAREPOINT ───────────────────────────────────────────────────────
# Obtidos no Azure App Registration (ver DOC_TEC seção 4.1)
AZURE_TENANT_ID=seu-tenant-id-aqui
AZURE_CLIENT_ID=seu-client-id-aqui
AZURE_CLIENT_SECRET=seu-client-secret-aqui

# URL exata do site SharePoint
SHAREPOINT_SITE_URL=https://luisamoraesadvogados.sharepoint.com/sites/ParticularAnderson

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=string-aleatoria-minimo-64-caracteres-NUNCA-commitar
JWT_EXPIRES_IN=24h

# ─── BANCO DE DADOS (produção) ────────────────────────────────────────────────
# Use uma URL Postgres real para persistência em produção (ex.: Supabase/Neon).
# Sem DATABASE_URL, o backend usa arquivos locais apenas para desenvolvimento.
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres
DATABASE_SSL=true
APP_STATE_TABLE=app_state

# ─── SESSÃO / JWT ─────────────────────────────────────────────────────────────
JWT_ISSUER=plumar-api
JWT_AUDIENCE=plumar-web
COOKIE_SAME_SITE=Lax
# Em produção cross-site (ex.: frontend e backend em domínios diferentes), use:
# COOKIE_SAME_SITE=None
# COOKIE_SECURE=true

# ─── USUÁRIOS ─────────────────────────────────────────────────────────────────
# Opcional: caminho customizado para o arquivo local de usuários.
# Se omitido, o backend usa backend/storage/users.json
USER_STORE_PATH=
CRIATORIO_STORE_PATH=
PLANTEL_STORE_PATH=

# Opcional: e-mails que receberão role admin automaticamente no cadastro inicial
ADMIN_EMAILS=admin@seudominio.com

# Conta proprietária com acesso vitalício
OWNER_EMAIL=proprietario@seudominio.com
OWNER_PASSWORD=senha-forte-aqui
OWNER_NAME=Nome do Proprietário
OWNER_ACCESS_KEY=anderson

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Em produção: FRONTEND_URL=https://seu-dominio.vercel.app
FRONTEND_PUBLIC_URL=https://app.seu-dominio.com
BACKEND_PUBLIC_URL=https://api.seu-dominio.com

# ─── GATEWAY DE PAGAMENTO ─────────────────────────────────────────────────────
PAYMENT_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=webhook-secret-opcional
MERCADOPAGO_STATEMENT_DESCRIPTOR=PLUMAR

# ─── E-MAILS DE LIBERAÇÃO ─────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp

# Opção 1: SMTP tradicional
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-senha-ou-app-password
SMTP_FROM_NAME=Plumar
SMTP_FROM_EMAIL=seu-email@dominio.com
MASTER_NOTIFICATION_EMAIL=anderson.assis@outlook.com.br

# Opção 2: Supabase Edge Function (como no Luma RH)
# EMAIL_PROVIDER=supabase_function
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxx
SUPABASE_EMAIL_FUNCTION_NAME=send-email
PASSWORD_RESET_TTL_MINUTES=60

# ─── LEMBRETES DE VENCIMENTO ──────────────────────────────────────────────────
SUBSCRIPTION_REMINDERS_ENABLED=true
SUBSCRIPTION_REMINDER_INTERVAL_HOURS=12

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
