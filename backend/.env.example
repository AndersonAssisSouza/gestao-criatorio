# ─── AZURE / SHAREPOINT ───────────────────────────────────────────────────────
# Obtidos no Azure App Registration (ver DOC_TEC seção 4.1)
AZURE_TENANT_ID=seu-tenant-id-aqui
AZURE_CLIENT_ID=seu-client-id-aqui
AZURE_CLIENT_SECRET=seu-client-secret-aqui

# URL exata do site SharePoint
SHAREPOINT_SITE_URL=https://luisamoraesadvogados.sharepoint.com/sites/ParticularAnderson

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=string-aleatoria-minimo-64-caracteres-NUNCA-commitar
JWT_EXPIRES_IN=24h

# ─── BANCO DE USUÁRIOS (Supabase) ─────────────────────────────────────────────
# Obter em: supabase.com → projeto → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Em produção: FRONTEND_URL=https://seu-dominio.vercel.app

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
